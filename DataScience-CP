bal])\n\nprint('C) WORD2VEC — AVERAGE EMBEDDINGS')\nprint('='*45)\nprint(f'  Vocabulary size       : {len(w2v_model.wv):,}')\nprint(f'  Embedding dimension   : {W2V_DIM}')\nprint(f'  Feature matrix shape  : {X_w2v.shape}')\nprint(f'  Matrix type           : Dense (all values filled)')\nprint(f'  OOV handling          : ✅ skipped (zero vector fallback)')\nprint(f'  Empty doc handling    : ✅ returns zero vector')\nprint(f'  Sample vector (doc 0) : {X_w2v[0, :6].round(4)}')\n\n# Test similar words\ntest_word = 'happy'\nif test_word in w2v_model.wv:\n    similar = w2v_model.wv.most_similar(test_word, topn=5)\n    print(f'\\n  Words similar to \"{test_word}\":')\n    for word, score in similar:\n        print(f'    {word:<15} similarity: {score:.4f}')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T09:41:41.137368Z","iopub.execute_input":"2026-03-28T09:41:41.137724Z","iopub.status.idle":"2026-03-28T09:41:57.540683Z","shell.execute_reply.started":"2026-03-28T09:41:41.137683Z","shell.execute_reply":"2026-03-28T09:41:57.540008Z"}},"outputs":[{"name":"stdout","text":"⏳ Training Word2Vec model...\nC) WORD2VEC — AVERAGE EMBEDDINGS\n=============================================\n  Vocabulary size       : 32,187\n  Embedding dimension   : 100\n  Feature matrix shape  : (69774, 100)\n  Matrix type           : Dense (all values filled)\n  OOV handling          : ✅ skipped (zero vector fallback)\n  Empty doc handling    : ✅ returns zero vector\n  Sample vector (doc 0) : [ 0.3677  0.5103  0.5506  0.0761 -0.2055  1.66  ]\n\n  Words similar to \"happy\":\n    wud             similarity: 0.6707\n    height          similarity: 0.6654\n    sucess          similarity: 0.6526\n    teser           similarity: 0.6162\n    reach           similarity: 0.6022\n","output_type":"stream"}],"execution_count":75},{"id":"bbc41421-78d1-44c8-bbc3-1b054f76f713","cell_type":"code","source":"# ── Vectorization Summary Chart ────────────────────────────────────────────\nfig, axes 