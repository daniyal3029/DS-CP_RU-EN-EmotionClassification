            'Level 1': lv1_map[emo],\n                'Level 2': emo\n            })\n\n    df = pd.DataFrame(rows).sample(frac=1, random_state=42).reset_index(drop=True)\n    df.insert(0, 'Unnamed: 0', df.index)\n    print('✅ Synthetic dataset ready.')\n\n# ── Clean dataset ──────────────────────────────────────────────────────────\ndf.dropna(subset=['Tweets'], inplace=True)\ndf.reset_index(drop=True, inplace=True)\n\nTEXT_COL  = 'Tweets'\nLABEL_COL = 'Level 2'\n\n# ── Print info ─────────────────────────────────────────────────────────────\nprint(f'\\n📊 Dataset Shape  : {df.shape}')\nprint(f'📋 Columns        : {list(df.columns)}')\nprint(f'❓ Missing Values :\\n{df.isnull().sum().to_string()}\\n')\n\n# ── Preview ────────────────────────────────────────────────────────────────\ndisplay(df.head(8))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T09:41:31.933498Z","iopub.execute_input":"2026-03-28T09:41:31.933789Z","iopub.status.idle":"2026-03-28T09:41:32.901947Z","shell.execute_reply.started":"2026-03-28T09:41:31.933760Z","shell.execute_reply":"2026-03-28T09:41:32.901266Z"}},"outputs":[{"name":"stdout","text":"📂 Searching for dataset...\n\n✅ Found file at: /kaggle/input/datasets/daniyalhaider3029/ru-en-emotion-dataset/RU-EN-Emotion Dataset.xlsx\n✅ Loaded from Kaggle input directory.\n\n📊 Dataset Shape  : (19999, 4)\n📋 Columns        : ['Unnamed: 0', 'Tweets', 'Level 1', 'Level 2']\n❓ Missing Values :\nUnnamed: 0    0\nTweets        0\nLevel 1       0\nLevel 2       0\n\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"   Unnamed: 0                                             Tweets  Level 1  \\\n0           0              yeh fair game nai thi I don’t like it  emotion   \n1           1  Nasir mama ban gya aur jija ji hinduo ko bol r...  emotion   \n2           2  : Part - #MissionMuzaffarabad #MasterShifujisM...  emotion   \n3           3  O bhai ghoor se daikho vehicle parking ki wjah...  emotion   \n4          