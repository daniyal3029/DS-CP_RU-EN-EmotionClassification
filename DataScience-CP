──────────────────────────────────────────\nX_raw = df['Processed'].values\ny_raw = df[LABEL_COL].values\n\n# RandomOverSampler needs 2D input\nX_idx = np.arange(len(X_raw)).reshape(-1, 1)\n\nros = RandomOverSampler(random_state=42)\nX_bal_idx, y_bal = ros.fit_resample(X_idx, y_raw)\n\n# Reconstruct text array from indices\nX_bal = np.array([X_raw[i[0]] for i in X_bal_idx])\n\ncounts_after = Counter(y_bal)\n\nprint(f'Samples BEFORE balancing : {len(X_raw):>7,}')\nprint(f'Samples AFTER  balancing : {len(X_bal):>7,}')\nprint(f'Added (oversampled)      : {len(X_bal)-len(X_raw):>7,}\\n')\nprint('Class counts AFTER balancing:')\nprint('='*35)\nfor cls, cnt in sorted(counts_after.items(), key=lambda x: -x[1]):\n    print(f'  {cls:<10}: {cnt:>6,}')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T09:41:36.717497Z","iopub.execute_input":"2026-03-28T09:41:36.717992Z","iopub.status.idle":"2026-03-28T09:41:37.025433Z","shell.execute_reply.started":"2026-03-28T09:41:36.717960Z","shell.execute_reply":"2026-03-28T09:41:37.024543Z"}},"outputs":[{"name":"stdout","text":"Samples BEFORE balancing :  19,999\nSamples AFTER  balancing :  69,774\nAdded (oversampled)      :  49,775\n\nClass counts AFTER balancing:\n===================================\n  Anger     : 11,629\n  Happy     : 11,629\n  Fear      : 11,629\n  Surprise  : 11,629\n  Sad       : 11,629\n  Neutral   : 11,629\n","output_type":"stream"}],"execution_count":71},{"id":"48bab7e5-cb45-4a8c-b9bb-319a12f3e144","cell_type":"code","source":"# ── Before vs After comparison chart ──────────────────────────────────────\nfig, axes = plt.subplots(1, 2, figsize=(14, 5))\ncolors = sns.color_palette(PALETTE, 6)\n\nfor ax, (data_dict, title, subtitle) in zip(axes, [\n    (dict(counts_before), 'BEFORE Balancing', 'Neutral: 58.1% | Surprise: 1.1%'),\n    (dict(counts_after),  'AFTER Balancing (Random Oversampling)', f'All classes: {list(counts_after.values())[0]:,} each'),\n]):\n    labels = list(data_dict.keys())\n    vals   = list(data_dict.values())\n    bars   = ax.bar(labels, vals, color=colors, edgecolor='white', linewidth=1.5, width=0.65)\n    for bar, v in zip(bars, vals):\n        ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + max(vals)*0.01,\n                f'{v:,}', ha='center', va='bottom', fontsize=8.5, fontweight='bold')\n    ax.set_title(f'{title}\\n({subtitle})', fontsize=11, fontweight='bold')\n    ax.set_xlabel('Emotion'); ax.set_ylabel('Count')\n    ax.tick_params(axis='x', rotation=20, labelsize=9)\n    ax.set_ylim(0, max(vals) * 1.18)\n\nplt.suptitle('Class Balancing: Before vs After', fontsize=14, fontweight='bold')\nplt.tight_layout()\nplt.savefig('class_dist_after.png', dpi=130, bbox_inches='tight')\nplt.show()\nprint('✅ Figure saved: class_dist_after.png')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T09:41:37.026400Z","iopub.execute_input":"2026-03-28T09:41:37.026712Z","iopub.status.idle":"2026-03-28T09:41:37.604271Z","shell.execute_reply.started":"2026-03-28T09:41:37.026684Z","shell.execute_reply":"2026-03-28T09:41:37.603493Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1400x500 with 2 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"✅ Figure saved: class_dist_after.png\n","output_type":"stream"}],"execution_count":72},{"id":"15ccef3f-5449-42b0-876c-ffa81cd74395","cell_type":"markdown","source":"### 📝 Balancing Interpretation\n\n- After oversampling, **all 6 classes have exactly 11,629 samples** each.\n- Total dataset grew from **20,000 → 69,774 rows** (minority classes were replicated).\n- Models can now **learn all emotions equally** without being biased toward Neutral.\n- Especially important for **Sad, Fear, and Surprise** which would otherwise be nearly ignored.\n\n> ✅ The balanced dataset ensures **fair evaluation** across all emotion classes and prevents deceptive high accuracy from majority-class bias.","metadata":{}},{"id":"8167364f-6f29-4988-882d-68e577503bef","cell_type":"markdown","source":"---\n## 🔢 Step 5 — Vectorization\n\nText must be converted to numbers before ML models can use it. We apply **3 techniques**:","metadata":{}},{"id":"f4bd8c01-0a2c-4aae-a90d-e14958a44fff","cell_type":"code","source":"# ═══════════════════════════════════════════════════════════\n# A) COUNT VECTORIZER\n# ═══════════════════════════════════════════════════════════\ncv   = CountVectorizer(max_features=5000)\nX_cv = cv.fit_transform(X_bal)\n\nprint('A) COUNT VECTORIZER')\nprint('='*45)\nprint(f'  Feature matrix shape  : {X_cv.shape}')\nprint(f'  Matrix type           : Sparse (memory efficient)')\nprint(f'  Top 10 features       : {list(cv.get_feature_names_out()[:10])}')\nprint(f'  Sample vector (doc 0) : {X_cv[0, :8].toarray()[0]}')\nprint(f'  Sparsity              : {(1 - X_cv.nnz / (X_cv.shape[0]*X_cv.shape[1]))*100:.1f}%')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T09:41:37.605276Z","iopub.execute_input":"2026-03-28T09:41:37.605501Z","iopub.status.idle":"2026-03-28T09:41:39.706865Z","shell.execute_reply.started":"2026-03-28T09:41:37.605476Z","shell.execute_reply":"2026-03-28T09:41:39.706021Z"}},"outputs":[{"name":"stdout","text":"A) COUNT VECTORIZER\n=============================================\n  Feature matrix shape  : (69774, 5000)\n  Matrix type           : Sparse (memory efficient)\n  Top 10 features       : ['aa', 'aaa', 'aaaap', 'aaapse', 'aab', 'aabi', 'aacha', 'aad', 'aadhi', 'aadmi']\n  Sample vector (doc 0) : [0 0 0 0 0 0 0 0]\n  Sparsity              : 99.7%\n","output_type":"stream"}],"execution_count":73},{"id":"bc553ce1-ec29-4e53-addd-614378f07516","cell_type":"code","source":"# ═══════════════════════════════════════════════════════════\n# B) TF-IDF VECTORIZER\n# ═══════════════════════════════════════════════════════════\ntfidf   = TfidfVectorizer(max_features=5000)\nX_tfidf = tfidf.fit_transform(X_bal)\n\nprint('B) TF-IDF VECTORIZER')\nprint('='*45)\nprint(f'  Feature matrix